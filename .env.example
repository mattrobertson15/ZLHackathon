# Backend Environment Variables
ANTHROPIC_API_KEY=your_key_here
QWEN_API_KEY=your_key_here
ROBOFLOW_API_KEY=your_key_here
UPLOAD_STORAGE_PATH=./uploads
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# Camera / RTSP emulation (multi-feed demo). The seeded demo cameras attach to
# f"{DEMO_RTSP_BASE_URL}/<path>". docker-compose overrides these for the private
# network; defaults below suit a backend running on the host against the emulator.
DEMO_RTSP_BASE_URL=rtsp://localhost:8554
# Auto-start monitoring on the seeded cameras. Leave false for plain local dev
# (no emulator) to avoid RTSP connection-error noise; docker-compose sets it true.
SEED_CAMERA_MONITORING=false
SEED_CAMERA_CAPTURE_INTERVAL_SECONDS=10

# Frontend Environment Variables
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
